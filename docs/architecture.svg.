<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="800" height="600" fill="#f8f9fa" />
  
  <!-- Title -->
  <text x="400" y="40" font-family="Arial, sans-serif" font-size="22" font-weight="bold" text-anchor="middle" fill="#202124">OneHealth-Sentinel System Architecture</text>
  <text x="400" y="65" font-family="Arial, sans-serif" font-size="14" text-anchor="middle" fill="#5f6368">Multi-Agent Spatiotemporal Disease Intelligence Pipeline</text>

  <!-- LAYER 1: DATA SOURCES -->
  <g id="data-sources">
    <rect x="180" y="100" width="440" height="80" rx="10" fill="none" stroke="#3c8dbc" stroke-dasharray="5,5" stroke-width="2" />
    <text x="400" y="92" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="#3c8dbc">1. MULTI-SECTORAL DATA SOURCES</text>
    
    <!-- Climate Data -->
    <rect x="200" y="115" width="180" height="50" rx="5" fill="#e8f0fe" stroke="#1a73e8" />
    <text x="290" y="135" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#174ea6">Climate Layers</text>
    <text x="290" y="152" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#174ea6">(18 Parameters: NDVI, LST, RH)</text>
    
    <!-- Clinical Data -->
    <rect x="420" y="115" width="180" height="50" rx="5" fill="#e8f0fe" stroke="#1a73e8" />
    <text x="510" y="135" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#174ea6">Veterinary Records</text>
    <text x="510" y="152" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#174ea6">(19 Pathogens, District Cases)</text>
  </g>

  <!-- LAYER 2: AGENT FACTORY -->
  <g id="agent-core">
    <rect x="150" y="210" width="500" height="180" rx="15" fill="#e6f4ea" stroke="#34a853" stroke-width="2" />
    <text x="400" y="202" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="#1e8e3e">2. MULTI-AGENT REASONING CORE (ADK)</text>

    <!-- Agent 1 -->
    <rect x="170" y="230" width="140" height="140" rx="8" fill="#ffffff" stroke="#34a853" />
    <text x="240" y="255" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#1e8e3e">Data Ingestion</text>
    <text x="240" y="272" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#1e8e3e">Agent</text>
    <line x1="180" y1="285" x2="300" y2="285" stroke="#34a853" stroke-width="1" />
    <text x="185" y="305" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• RBAC Authorization</text>
    <text x="185" y="325" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Range Validation</text>
    <text x="185" y="345" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Biophysical Clipping</text>

    <!-- Agent 2 -->
    <rect x="330" y="230" width="140" height="140" rx="8" fill="#ffffff" stroke="#34a853" />
    <text x="400" y="255" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#1e8e3e">Risk Analysis</text>
    <text x="400" y="272" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#1e8e3e">Agent</text>
    <line x1="340" y1="285" x2="460" y2="285" stroke="#34a853" stroke-width="1" />
    <text x="345" y="305" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Sigmoid Scoring</text>
    <text x="345" y="325" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• R0 NGM Modeling</text>
    <text x="345" y="345" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Pathogen Profiles</text>

    <!-- Agent 3 -->
    <rect x="490" y="230" width="140" height="140" rx="8" fill="#ffffff" stroke="#34a853" />
    <text x="560" y="255" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#1e8e3e">Communication</text>
    <text x="560" y="272" font-family="Arial, sans-serif" font-size="10" text-anchor="middle" fill="#1e8e3e">Agent</text>
    <line x1="500" y1="285" x2="620" y2="285" stroke="#34a853" stroke-width="1" />
    <text x="505" y="305" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Bulletin Indexing</text>
    <text x="505" y="325" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• GIS GeoJSON Export</text>
    <text x="505" y="345" font-family="Arial, sans-serif" font-size="9" fill="#5f6368">• Local Language Adv.</text>
  </g>

  <!-- SIDE COMPONENT: SECURITY HARNESS -->
  <g id="security-harness">
    <rect x="670" y="210" width="120" height="180" rx="10" fill="#fce8e6" stroke="#d93025" stroke-width="2" />
    <text x="730" y="230" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#d93025">Security Harness</text>
    <text x="680" y="260" font-family="Arial, sans-serif" font-size="10" fill="#a50e0e">• JIT Downscoping</text>
    <text x="680" y="285" font-family="Arial, sans-serif" font-size="10" fill="#a50e0e">• Policy Gating</text>
    <text x="680" y="310" font-family="Arial, sans-serif" font-size="10" fill="#a50e0e">• Vibe Diff HITL</text>
    <text x="680" y="335" font-family="Arial, sans-serif" font-size="10" fill="#a50e0e">• Semgrep SAST</text>
  </g>

  <!-- SIDE COMPONENT: MCP INTEROP -->
  <g id="mcp-interop">
    <rect x="10" y="210" width="120" height="180" rx="10" fill="#fef7e0" stroke="#f29900" stroke-width="2" />
    <text x="70" y="230" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#f29900">MCP Interop</text>
    <text x="20" y="260" font-family="Arial, sans-serif" font-size="10" fill="#b06000">• Stdio Socket</text>
    <text x="20" y="285" font-family="Arial, sans-serif" font-size="10" fill="#b06000">• Sample Calc</text>
    <text x="20" y="310" font-family="Arial, sans-serif" font-size="10" fill="#b06000">• Pathogen DB</text>
    <text x="20" y="335" font-family="Arial, sans-serif" font-size="10" fill="#b06000">• Tool Discovery</text>
  </g>

  <!-- LAYER 3: OUTPUTS -->
  <g id="outputs">
    <rect x="150" y="440" width="500" height="120" rx="10" fill="none" stroke="#00c0ef" stroke-dasharray="5,5" stroke-width="2" />
    <text x="400" y="432" font-family="Arial, sans-serif" font-size="12" font-weight="bold" text-anchor="middle" fill="#00c0ef">3. INTERACTIVE OUTCOMES &amp; GUI</text>

    <!-- R Shiny -->
    <rect x="170" y="460" width="140" height="80" rx="5" fill="#e0f7fa" stroke="#01acc1" />
    <text x="240" y="485" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#006064">R Shiny Web UI</text>
    <text x="240" y="505" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">KPIs, Bar Charts,</text>
    <text x="240" y="520" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">Compliance Matrix</text>

    <!-- GIS Asset -->
    <rect x="330" y="460" width="140" height="80" rx="5" fill="#e0f7fa" stroke="#01acc1" />
    <text x="400" y="485" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#006064">GIS Asset</text>
    <text x="400" y="505" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">GeoJSON Point</text>
    <text x="400" y="520" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">Collections</text>

    <!-- Bulletins -->
    <rect x="490" y="460" width="140" height="80" rx="5" fill="#e0f7fa" stroke="#01acc1" />
    <text x="560" y="485" font-family="Arial, sans-serif" font-size="11" font-weight="bold" text-anchor="middle" fill="#006064">Bulletin Library</text>
    <text x="560" y="505" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">Historical MD</text>
    <text x="560" y="520" font-family="Arial, sans-serif" font-size="9" text-anchor="middle" fill="#006064">Prediction Archives</text>
  </g>

  <!-- Connectors -->
  <g stroke="#5f6368" stroke-width="1.5" fill="none">
    <path d="M 290 165 L 290 210" marker-end="url(#arrow)" />
    <path d="M 510 165 L 510 210" marker-end="url(#arrow)" />
    <path d="M 240 390 L 240 440" marker-end="url(#arrow)" />
    <path d="M 400 390 L 400 440" marker-end="url(#arrow)" />
    <path d="M 560 390 L 560 440" marker-end="url(#arrow)" />
    <path d="M 130 300 L 150 300" marker-end="url(#arrow)" />
    <path d="M 670 300 L 650 300" marker-end="url(#arrow)" />
  </g>

  <!-- Arrow Marker Definition -->
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#5f6368" />
    </marker>
  </defs>
</svg>
